{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "OnlyCloudFrontReadAccess",
            "Principal": {
                "AWS": "${origin_access_identity_arn}"
            },
            "Effect": "Allow",
            "Action": [
                "s3:GetObject"
            ],
            "Resource": "arn:aws:s3:::${bucket}/*"
        }
    ]
}